// ============================================================
// test_stub 配置 — stub-run DAG 快速校验，不依赖容器
// ============================================================
process {
    // 使用本地 shell 执行 stub（无需容器）
    container = ''
    // stub-run 无需真实资源，压低限制以适配小内存测试机
    cpus   = 1
    memory = 256.MB
    time   = 5.m

    withLabel: process_low    { cpus = 1; memory = 256.MB; time = 5.m }
    withLabel: process_medium { cpus = 1; memory = 256.MB; time = 5.m }
    withLabel: process_high   { cpus = 1; memory = 256.MB; time = 5.m }
    withLabel: process_R      { cpus = 1; memory = 256.MB; time = 5.m }
}

docker.enabled = false
apptainer.enabled = false
