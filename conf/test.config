// ============================================================
// test 配置 — E. coli 端到端完整测试
// ============================================================

process {
    // 覆盖内存限制，适配本机 (E. coli 基因组 ~5MB，资源需求很低)
    cpus   = 2
    memory = 2.GB
    time   = 1.h

    withLabel: process_low    { cpus = 2; memory = 2.GB; time = 1.h }
    withLabel: process_medium { cpus = 2; memory = 4.GB; time = 1.h }
    withLabel: process_high   { cpus = 4; memory = 4.GB; time = 1.h }
    withLabel: process_R      { cpus = 2; memory = 2.GB; time = 1.h }
}

// 容器本地执行（用 mamba 环境替代）
process.container = ''

docker.enabled = false
apptainer.enabled = false

// E. coli: NCBI GTF exon 只有 216 行，用 gene 层直接计数
params.featurecounts.feature_type = "gene"
params.featurecounts.attr_type = "gene"
params.clusterprofiler.org_db = "org.EcK12.eg.db"
params.clusterprofiler.kegg_organism = "eco"
params.clusterprofiler.from_type = "SYMBOL"
params.clusterprofiler.gene_id_col = "gene_id"
params.clusterprofiler.show_category = 10
