// ============================================================
// 基础资源配置（所有 profile 共享）
// ============================================================

process {
    cpus   = 2
    memory = 2.GB
    time   = 4.h

    // 按退出码区分策略：OOM(137) / HPC抢占(143) 重试，其他错误直接终止
    errorStrategy = { task.exitStatus in [137, 143] ? 'retry' : 'terminate' }
    maxRetries    = 2

    withLabel: process_low {
        cpus   = 2
        memory = 4.GB
        time   = 2.h
    }
    withLabel: process_medium {
        cpus   = 4
        memory = 16.GB
        time   = 6.h
    }
    withLabel: process_high {
        cpus   = 8
        memory = 32.GB
        time   = 12.h
    }
    withLabel: process_R {
        cpus   = 2
        memory = 8.GB
        time   = 4.h
    }
}
