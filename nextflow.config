// ============================================================
// RNA-seq 上游分析流程 — Nextflow 配置文件
// ============================================================

// ---- 管线元数据 ----
manifest {
    name        = 'nextflow-rnaseq'
    version     = '1.0.0'
    description = 'RNA-seq upstream analysis: FastQC → Trimmomatic → HISAT2 → featureCounts → MultiQC → DESeq2 → clusterProfiler'
    author      = 'Muyi-bioinfo'
    mainScript  = 'main.nf'
    defaultBranch = 'main'
}

// ---- nf-validation 插件 (启用 nextflow_schema.json 参数校验) ----
plugins {
    id 'nf-validation'
}

// ---- 用户参数（全部可通过命令行 --xxx 覆盖）----
params {
    // 输入
    input      = null                              // samplesheet CSV 路径（必需）
    read_mode  = "paired"                          // "paired" | "single"

    // 输出
    outdir     = "./results"                       // 最终结果目录

    // 参考基因组（用户必须通过命令行提供）
    genome_fasta        = null
    annotation_gtf      = null
    hisat2_index_prefix = null                     // 不设置则自动推导
    adapter_fasta       = null

    // ---- FastQC 参数 ----
    fastqc {
        extra   = ""
    }

    // ---- Trimmomatic 参数 ----
    trimmomatic {
        phred         = "33"       // "33" | "64" — Phred 质量编码 (空字符串=自动检测)
        illuminaclip  = "2:30:10"
        leading       = 3
        trailing      = 3
        slidingwindow = "4:15"
        minlen        = 36
    }

    // ---- HISAT2 参数 ----
    hisat2 {
        extra   = ""
    }

    // ---- featureCounts 参数 ----
    featurecounts {
        feature_type  = "exon"
        attr_type     = "gene_id"
        strandedness  = 0
        extra         = ""
    }

    // ---- DESeq2 参数 ----
    deseq2 {
        padj_threshold        = 0.05
        log2fc_threshold      = 1.0
        independent_filtering = true
        vst_blind             = true
        top_n_genes           = 50
        contrasts = [
            [name: "KO_vs_WT", 'case': "KO", control: "WT"]
        ]
    }

    // ---- clusterProfiler 参数 ----
    clusterprofiler {
        org_db        = "org.Hs.eg.db"
        kegg_organism = "hsa"
        from_type     = "ENSEMBL"
        pvalue_cutoff = 0.05
        qvalue_cutoff = 0.2
        show_category = 15
        gene_id_col   = "gene_id"
    }
}

// ---- 容器 ----
process.container = 'rnaseq-pipeline:1.0.0'

// ---- 共享资源配置 ----
includeConfig 'conf/base.config'

// ---- Profile ----
profiles {
    docker {
        includeConfig 'conf/docker.config'
    }
    apptainer {
        includeConfig 'conf/apptainer.config'
    }
    test {
        includeConfig 'conf/test.config'
    }
    test_stub {
        includeConfig 'conf/test_stub.config'
    }
}

// ---- DAG ----
dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_dag.svg"
    overwrite = true
}

// ---- 报告 ----
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_timeline.html"
}
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_report.html"
}
